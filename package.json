{
  "name": "sleepywear",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @sleepywear/database prisma:generate",
    "db:migrate": "pnpm --filter @sleepywear/database prisma:migrate",
    "db:seed": "pnpm --filter @sleepywear/database prisma:seed"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  }
}
